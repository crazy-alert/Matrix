{$MATRIX_DOMAIN} {
# Основной прокси на Synapse (порт 8008 внутри сети)
    handle_path /_matrix/* {
        reverse_proxy synapse:8008
    }

     handle_path /_synapse/client/* {
        reverse_proxy synapse:8008
    }
     # Опционально: если хотите отдавать что-то ещё на этом домене
     respond 404
 }

{$ELEMENT_DOMAIN} {
    reverse_proxy element:80
}

# Отдельный блок для административной панели
admin.{$MATRIX_DOMAIN} {
    reverse_proxy synapse-admin:80
}

# Критически важные endpoints на корневом домене для федерации
{$ROOT_DOMAIN} {
    # Отдаем файлы .well-known для matrix federation
    handle /.well-known/matrix/server {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.server": "{$MATRIX_DOMAIN}:443"}`
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver": {"base_url": "https://{$MATRIX_DOMAIN}"}}`
    }

    # Все остальные запросы на корневой домен можно проксировать на ваш основной сайт
    # handle {
    #     reverse_proxy ваш_основной_сайт
    # }
    respond 404
}