# Основной домен вашего сервера (без поддоменов)
DOMAIN=example.org

# Версии используемых образов (можно менять при необходимости)
SYNAPSE_VERSION=latest
POSTGRES_VERSION=14-alpine
COTURN_VERSION=latest
CADDY_VERSION=2-alpine

# Настройки базы данных PostgreSQL
POSTGRES_PASSWORD=YourStrongPasswordHereChangeMe# Придумайте надёжный пароль

# Email для уведомлений Let's Encrypt (обязателен для получения SSL-сертификатов)
CADDY_EMAIL=admin@example.org

# Настройки Coturn (если нужны звонки) — обычно IP адреса
# Внешний IP сервера (публичный)
COTURN_EXTERNAL_IP=ваш_публичный_айпи
# Внутренний IP сервера (в локальной сети, можно узнать командой hostname -I)
COTURN_INTERNAL_IP=ваш_внутренний_айпи
# Секретный ключ для Coturn (сгенерируйте случайную строку)
COTURN_STATIC_AUTH_SECRET=YourSecretKeyChangeMe